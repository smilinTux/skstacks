# .env.example — Docker Swarm platform environment variables
#
# Copy to .env (or export in CI/CD) and fill in real values.
# Never commit the populated .env file to version control.

# ── Swarm networking ─────────────────────────────────────────────────────────

# Management IP of the primary (bootstrap) manager node.
# This is the node's actual IP, not the VIP.
SWARM_MANAGER_IP=

# Floating Virtual IP for HA (keepalived VRRP).
# Must be unused and in the same /24 as the manager nodes.
SWARM_VIP=

# CIDR to restrict swarm management ports (2377, 7946) via UFW.
# Use the cluster's private network, e.g. 10.0.0.0/8, or leave empty for 'any'.
SWARM_MANAGEMENT_CIDR=

# ── Domain / TLS ─────────────────────────────────────────────────────────────

# Primary domain served by this cluster.
DOMAIN=

# Let's Encrypt ACME email (used for expiry notifications).
ACME_EMAIL=

# Cloudflare DNS API token for ACME DNS-01 challenge.
# Needs Zone.DNS:Edit permission for the target zone.
CF_DNS_API_TOKEN=

# ── Traefik ──────────────────────────────────────────────────────────────────

# Host path for Traefik static config (traefik.yml) and dynamic config dir.
TRAEFIK_CONFIG_DIR=/var/data/config/traefik

# Host path for acme.json certificate storage.
TRAEFIK_ACME_DIR=/var/data/runtime/traefik/acme

# Host path for Traefik access and error logs.
TRAEFIK_LOGS_DIR=/var/data/logs/traefik

# CIDR allowed to access the Traefik dashboard (port 8080).
# Restrict to VPN/management network in production.
TRAEFIK_DASHBOARD_CIDR=

# Dashboard basic-auth credentials hash (htpasswd -nB admin | sed 's/\$/\$\$/g').
TRAEFIK_DASHBOARD_AUTH=

# ── Overlay networks ─────────────────────────────────────────────────────────

# Subnets for Traefik overlay networks (must not conflict with host networks).
TRAEFIK_PUBLIC_SUBNET=172.16.100.0/24
TRAEFIK_INTERNAL_SUBNET=172.16.101.0/24

# ── Ansible SSH ──────────────────────────────────────────────────────────────

# SSH user on managed nodes (must have passwordless sudo).
ANSIBLE_USER=

# Individual node IPs (used in inventory.example substitution).
MANAGER_01_IP=
MANAGER_02_IP=
MANAGER_03_IP=
WORKER_01_IP=
WORKER_02_IP=

# ── Environment tag ──────────────────────────────────────────────────────────
# prod | staging | dev  — used to tag overlay networks and Traefik router names.
ENV=prod
