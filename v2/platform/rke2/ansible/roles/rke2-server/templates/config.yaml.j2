# /etc/rancher/rke2/config.yaml — generated by Ansible (rke2-server role)
# Do not edit manually; re-run the Ansible playbook to update.

# Cluster token (used by agents and additional servers to join)
{% if rke2_is_init_server %}
token: {{ lookup('password', '/dev/null length=64 chars=ascii_letters,digits') }}
{% else %}
token: {{ _rke2_token_raw.content | b64decode | trim }}
server: https://{{ rke2_vip_ip }}:9345    # Join URL (port 9345, not 6443)
{% endif %}

# Advertise the VIP (so kubeconfig points to the VIP, not a single node)
tls-san:
  - {{ rke2_vip_ip }}
  - {{ cluster_name }}.{{ cluster_domain }}
  - "*.{{ cluster_name }}.{{ cluster_domain }}"

# Network
cni: {{ rke2_cni | default('canal') }}
cluster-cidr: {{ rke2_cluster_cidr }}
service-cidr: {{ rke2_service_cidr }}

# Disable components we replace (ingress-nginx replaces Traefik)
disable:
  - rke2-ingress-nginx    # We deploy our own via manifests/
  - rke2-canal            # Only if using an alternative CNI

# Node labels
node-label:
  - "skstacks.io/cluster={{ cluster_name }}"
  - "skstacks.io/role=server"
  - "skstacks.io/env={{ env | default('prod') }}"

# Audit log (required for CIS Level 2)
kube-apiserver-arg:
  - "audit-log-path=/var/log/rke2/audit.log"
  - "audit-log-maxage=30"
  - "audit-log-maxbackup=5"
  - "audit-log-maxsize=100"
  - "audit-policy-file=/etc/rancher/rke2/audit-policy.yaml"

# kubelet hardening
kubelet-arg:
  - "protect-kernel-defaults=true"
  - "streaming-connection-idle-timeout=5m"
  - "make-iptables-util-chains=true"
  - "event-qps=0"
  - "read-only-port=0"

# etcd snapshots
etcd-snapshot-schedule-cron: "0 */6 * * *"
etcd-snapshot-retention: 10
