# ── k3d cluster identity ──────────────────────────────────────────────────────
# Which cluster config to use: local | ci | staging | prod-edge
K3D_CONFIG=local

# Cluster name — becomes the kubeconfig context prefix: k3d-<name>
K3D_CLUSTER_NAME=skstacks

# k3s image — pin for reproducibility; check https://hub.docker.com/r/rancher/k3s/tags
K3D_IMAGE=rancher/k3s:v1.29.4-k3s1

# ── Cluster topology (staging config) ────────────────────────────────────────
# Ignored for local/ci/prod-edge configs (topology is hardcoded in their YAML).
K3D_SERVERS=3
K3D_AGENTS=2

# ── Load balancer ports (staging config) ──────────────────────────────────────
# Staging uses non-standard ports to avoid conflicts with host services on 80/443.
# local.yaml hardcodes 80:80 / 443:443 (no override needed for local dev).
K3D_LB_PORT_HTTP=8080
K3D_LB_PORT_HTTPS=8443

# ── Persistent data (prod-edge config only) ───────────────────────────────────
# Host-side path mounted into the k3s container as /var/lib/rancher/k3s.
# Ensure the directory exists and is writable before creating the cluster.
K3D_DATA_DIR=/var/lib/k3d-skstacks

# ── Registry mirrors (prod-edge config) ───────────────────────────────────────
# Override to point at a local registry proxy (e.g. harbor, distribution, nexus).
K3D_REGISTRY_MIRROR=https://registry-1.docker.io
K3D_GHCR_MIRROR=https://ghcr.io

# ── Secret backend (shared with all SKStacks platforms) ───────────────────────
# vault-file    — Ansible Vault AES-256 (default, no external deps)
# hashicorp-vault — HashiCorp Vault KV-v2 (recommended for teams)
# capauth       — PGP blobs via skcapstone MCP (sovereign agent mesh)
SECRET_BACKEND=vault-file
SKSTACKS_SECRET_BACKEND=vault-file
