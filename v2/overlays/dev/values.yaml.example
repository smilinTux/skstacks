# SKStacks v2 — Dev overlay values
# Dev uses self-signed certs and minimal resources.

env: dev
cluster_name: CHANGEME_CLUSTER_NAME
domain: dev.CHANGEME_DOMAIN

vip_ip: "CHANGEME_DEV_VIP_IP"
vip_interface: "CHANGEME_IFACE"
metallb_pool: ""                           # optional in dev

swarm_networks:
  cloud_edge:    "172.16.94.0/24"
  cloud_public:  "172.16.202.0/24"
  socket_proxy:  "172.16.95.0/24"

cert_resolver: selfsigned                  # No Let's Encrypt in dev
acme_email: ""

skfence:
  replicas: 1
  resources:
    limits:   { cpu: "200m", memory: "128Mi" }
    requests: { cpu: "50m",  memory: "32Mi" }

sksso:
  replicas: 1

backup_target: ""                          # No backup in dev

secret_backend: vault-file
